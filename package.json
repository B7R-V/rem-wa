{
  "name": "rem-wa",
  "version": "1.0.0",
  "description": "A professional WhatsApp bot framework built on Baileys. Forked and customized by B7R.",
  "license": "MIT",
  "author": {
    "name": "B7R",
    "url": "https://github.com/B7R-V"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/B7R-V/rem-wa.git"
  },
  "bugs": {
    "url": "https://github.com/B7R-V/rem-wa/issues"
  },
  "homepage": "https://github.com/B7R-V/rem-wa#readme",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "watch": "tsup src/index.ts --format esm,cjs --dts --watch",
    "start": "node dist/index.cjs"
  },
  "keywords": [
    "whatsapp",
    "bot",
    "rem-wa",
    "baileys",
    "whatsapp-bot",
    "chatbot",
    "whatsapp-api",
    "bot-library"
  ],
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "cheerio": "1.0.0-rc.12",
    "pino": "^10.3.0",
    "level": "^10.0.0",
    "qrcode-terminal": "^0.12.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.0.10",
    "nodemon": "^3.1.11",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typescript": "^4.9.5"
  }
}